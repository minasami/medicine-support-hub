# Medicine Support Hub — environment configuration template
# Never commit real credentials. Configure production secrets in Vercel.

# Public Supabase client configuration
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-publishable-key

# Server-only Supabase access for scheduled ingestion and index refresh
# Never prefix this variable with VITE_ or expose it to browser code.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Scheduled automation authentication
# Vercel Cron sends this as: Authorization: Bearer <CRON_SECRET>
CRON_SECRET=generate-a-long-random-secret

# Firecrawl provider
# Cloud default: https://api.firecrawl.dev
# A separately deployed self-hosted Firecrawl service can be supplied instead.
FIRECRAWL_API_BASE_URL=https://api.firecrawl.dev
FIRECRAWL_API_KEY=replace-with-a-rotated-server-side-key
# Set true only when the self-hosted endpoint requires Bearer authentication.
FIRECRAWL_REQUIRE_AUTH=false
# Local development only. Production remains HTTPS-only.
FIRECRAWL_ALLOW_INSECURE_LOCALHOST=false

# Google Enterprise Document OCR
GOOGLE_DOCUMENT_AI_PROJECT_ID=your-google-cloud-project
GOOGLE_DOCUMENT_AI_LOCATION=us
GOOGLE_DOCUMENT_AI_PROCESSOR_ID=your-processor-id
GOOGLE_SERVICE_ACCOUNT_EMAIL=service-account@project.iam.gserviceaccount.com
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nreplace-me\n-----END PRIVATE KEY-----\n"
OCR_MAX_FILE_MB=3

# Optional governed medicine-image discovery
BING_IMAGE_SEARCH_KEY=your-server-side-image-search-key

# Optional application/backend settings
DATABASE_URL=postgresql://username:password@localhost:5432/chronicmed
PORT=8080
NODE_ENV=development
LOG_LEVEL=info
SESSION_SECRET=generate-a-long-random-session-secret

# Optional OpenAI integration for server-side AI features
AI_INTEGRATIONS_OPENAI_BASE_URL=https://api.openai.com/v1
AI_INTEGRATIONS_OPENAI_API_KEY=your-server-side-openai-key

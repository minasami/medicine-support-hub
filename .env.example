# ChronicMed — Environment Configuration Template

# Database Connection (Required)
# A PostgreSQL database connection string is required for migrations, seeding, and operation.
DATABASE_URL=postgresql://username:password@localhost:5432/chronicmed

# Port settings (Optional)
# Port for the Express backend API server (defaults to 8080)
PORT=8080

# Application Environment (Optional)
# Set to 'production' or 'development' (defaults to development)
NODE_ENV=development

# Logging Configuration (Optional)
# Options: fatal, error, warn, info, debug, trace, silent
LOG_LEVEL=info

# Auth Session Secret (Required in production)
# Session secret used for signing authentication cookies.
SESSION_SECRET=a-long-random-fallback-secret-key-change-this-in-production

# AI Integrations (Optional, used for OCR and Clinical Support AI Assistant)
# When set, the system uses OpenAI services. If unset, it runs with mock/simulated fallbacks.
AI_INTEGRATIONS_OPENAI_BASE_URL=https://api.openai.com/v1
AI_INTEGRATIONS_OPENAI_API_KEY=your-openai-api-key-here

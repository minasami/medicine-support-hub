{
  "name": "medicine-support-hub",
  "version": "0.0.0",
  "license": "MIT",
  "private": true,
  "packageManager": "pnpm@10.28.0",
  "engines": {
    "node": ">=22 <23"
  },
  "scripts": {
    "preinstall": "sh -c 'rm -f package-lock.json yarn.lock; case \"$npm_config_user_agent\" in pnpm/*) ;; *) echo \"Use pnpm instead\" >&2; exit 1 ;; esac'",
    "dev": "pnpm --filter @workspace/web dev",
    "build": "pnpm --filter @workspace/web build"
  },
  "devDependencies": {
    "prettier": "^3.9.4",
    "typescript": "~6.0.3"
  },
  "dependencies": {
    "xlsx": "^0.18.5"
  }
}
